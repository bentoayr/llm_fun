Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Main", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"CallLLMWithPromptTemplate", "[", 
     RowBox[{"promptTemplate_String", ",", "inputPrompt_String"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "fullPrompt", "}"}], ",", 
      RowBox[{
       RowBox[{"fullPrompt", "=", 
        RowBox[{"TemplateApply", "[", 
         RowBox[{
          RowBox[{"StringTemplate", "[", "promptTemplate", "]"}], ",", 
          RowBox[{"<|", 
           RowBox[{"\"\<input\>\"", "->", "inputPrompt"}], "|>"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"LLMSynthesize", "[", "fullPrompt", "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9840466045000896`*^9, 3.984046643031494*^9}, {
